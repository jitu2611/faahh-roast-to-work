{
  "name": "faahh-roast-to-work",
  "version": "1.0.0",
  "description": "AI-powered focus app that roasts you back to work using Claude AI",
  "main": "src/main.js",
  "author": "jitu2611",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jitu2611/faahh-roast-to-work.git"
  },
  "keywords": [
    "productivity",
    "focus",
    "electron",
    "ai",
    "claude",
    "roast",
    "tray-app"
  ],
  "scripts": {
    "start": "electron .",
    "dev": "cross-env NODE_ENV=development electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "electron-store": "^8.1.0",
    "node-notifier": "^10.0.1",
    "play-sound": "^1.1.6"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.faahh.roast-to-work",
    "productName": "Faahh",
    "copyright": "Copyright © 2026 jitu2611",
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"],
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "assets/icon.png",
      "category": "Utility"
    },
    "files": [
      "src/**/*",
      "renderer/**/*",
      "sounds/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ]
  }
}
